# MongoDB Connection
# Local: mongodb://localhost:27017/tracktok
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/tracktok
MONGODB_URI=mongodb://localhost:27017/tracktok

# JWT Secret (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=tracktok_dev_secret_key_change_in_production

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=TrackTok
NEXT_PUBLIC_APP_VERSION=1.0.0

# Optional: Third-party services
# SENDGRID_API_KEY=your_sendgrid_key
# STRIPE_API_KEY=your_stripe_key
# STRIPE_PUBLIC_KEY=your_stripe_public_key
